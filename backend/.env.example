VOYAGE_API_KEY=your_voyage_api_key_here
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/
MONGODB_CONNECTION_STRING=mongodb+srv://user:password@cluster.mongodb.net/

# --- Session-based auth ---
# Cookie security. For local HTTP development set COOKIE_SECURE=false so the
# browser will store the cookie over http://localhost.
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=

# Session lifetime
SESSION_TTL_SECONDS=86400
SESSION_SLIDING=true

# Brute-force lockout
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900

# Session binding (hijacking mitigation)
BIND_SESSION_TO_USER_AGENT=true
BIND_SESSION_TO_IP=false

# --- Google OAuth (Authorization Code flow) ---
# From Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0
# Client ID (type: Web application). Register the redirect URI there EXACTLY.
# Leave id/secret empty to disable Google sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
# Where to send the browser (the SPA) after the OAuth callback finishes.
OAUTH_POST_LOGIN_REDIRECT=http://localhost:5173/
# Long random string in production — signs the temporary OAuth-state cookie.
OAUTH_STATE_SECRET=change-me-dev-only-oauth-state-secret
